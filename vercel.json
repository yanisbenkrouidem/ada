{
    "version": 2,
    "framework": null,
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.9.0",
            "config": {
                "excludeFiles": ["node_modules/**", "public/images/**", "public/video/**", "public/build/**", "public/fonts/**", "storage/logs/**", "basededonnée/**", "tests/**"]
            }
        },
        {
            "src": "/public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/(build|assets|images|js|css|storage)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_NAME": "ADA Location",
        "APP_ENV": "production",
        "APP_KEY": "base64:tTTwFgjO053papbsjmamb/c8iwDt5i7CJsRGHeKEm1o=",
        "APP_DEBUG": "false",
        "APP_URL": "https://ada.benkrouidem.com",
        "LOG_CHANNEL": "stderr",
        "APP_CONFIG_CACHE": "/tmp/config.php",
        "APP_EVENTS_CACHE": "/tmp/events.php",
        "APP_PACKAGES_CACHE": "/tmp/packages.php",
        "APP_ROUTES_CACHE": "/tmp/routes.php",
        "APP_SERVICES_CACHE": "/tmp/services.php",
        "VIEW_COMPILED_PATH": "/tmp",
        "DB_CONNECTION": "mysql",
        "DB_HOST": "mysql-yanis.alwaysdata.net",
        "DB_PORT": "3306",
        "DB_DATABASE": "yanis_ada",
        "DB_USERNAME": "yanis",
        "DB_PASSWORD": "Yanis120705.",
